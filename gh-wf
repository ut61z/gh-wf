#!/usr/bin/env bash
#
# gh-wf: カレントリポの .github/workflows/ を fzf で検索・プレビューする gh 拡張。
#
# Actions UI と違い、データソースをローカルの現存 yaml にしているので
# 「削除済みだが run 履歴が残っているワークフロー」は自動的に除外される。
#
# Usage:
#   gh wf            # Enter = そのワークフローの run 一覧から run を選んでブラウザで開く
#   gh wf --web      # Enter = ブラウザでそのワークフローを開く
#
# Keybinds (fzf 内):
#   Enter   起動オプションに応じて run 選択 or ブラウザ
#   Ctrl-O  ブラウザでワークフローを開く
#   Ctrl-R  run 一覧から run を選んでブラウザで開く
#   Ctrl-E  $EDITOR で yaml を開く
#   Ctrl-Y  ファイル名をクリップボードにコピー
#
set -euo pipefail

for c in fzf gh; do
  command -v "$c" >/dev/null || { echo "gh-wf: '$c' が必要です" >&2; exit 1; }
done

root=$(git rev-parse --show-toplevel 2>/dev/null) \
  || { echo "gh-wf: git リポジトリ内で実行してください" >&2; exit 1; }
dir="$root/.github/workflows"
[ -d "$dir" ] || { echo "gh-wf: $dir がありません" >&2; exit 1; }

script_path=$(realpath "$0" 2>/dev/null || printf '%s' "$0")
script_path_q=$(printf '%q' "$script_path")

list_runs() {
  local workflow=$1
  local status=${2:-}
  local result_filter=

  if [ "$status" = "without_skipped" ]; then
    result_filter=$status
  fi

  if [ -n "$status" ] && [ "$status" != "without_skipped" ]; then
    gh run list \
      --workflow="$workflow" \
      --status "$status" \
      --limit 50 \
      --json databaseId,status,conclusion,event,headBranch,createdAt,displayTitle \
      --jq '.[] | [.databaseId, .status, (.conclusion // "-"), .event, (.headBranch // "-"), .createdAt, (.displayTitle // "-")] | @tsv'
  else
    gh run list \
      --workflow="$workflow" \
      --limit 50 \
      --json databaseId,status,conclusion,event,headBranch,createdAt,displayTitle \
      --jq '.[] | [.databaseId, .status, (.conclusion // "-"), .event, (.headBranch // "-"), .createdAt, (.displayTitle // "-")] | @tsv'
  fi \
    | awk -v result_filter="$result_filter" -F '\t' '
          BEGIN {
            fmt = "%-11s  %-12s  %-14s  %-30s  %-16s  %s"
          }
          function shorten(value, width) {
            return length(value) > width ? substr(value, 1, width - 1) "~" : value
          }
          {
            if (result_filter == "without_skipped" && $3 == "skipped") {
              next
            }
            result = shorten(($2 == "completed" ? $3 : $2), 12)
            event = shorten($4, 14)
            branch = shorten($5, 30)
            created = substr($6, 1, 16)
            gsub("T", " ", created)
            line = sprintf(fmt, $1, result, event, branch, created, $7)
            print $1 "\t" line
          }
        '
}

show_runs() {
  local workflow=$1
  local selected
  local workflow_q

  workflow_q=$(printf '%q' "$workflow")

  selected=$(
    list_runs "$workflow" \
      | fzf \
          --prompt 'run all> ' \
          --delimiter '\t' \
          --with-nth 2.. \
          --header 'ID           RESULT        EVENT          BRANCH                          CREATED           TITLE
Ctrl-A all / Ctrl-X no-skip / Ctrl-P ok / Ctrl-F fail / Ctrl-L cancel / Ctrl-G running' \
          --bind 'enter:accept' \
          --bind "ctrl-a:reload($script_path_q --list-runs $workflow_q)+change-prompt(run all> )" \
          --bind "ctrl-x:reload($script_path_q --list-runs $workflow_q without_skipped)+change-prompt(run without skipped> )" \
          --bind "ctrl-p:reload($script_path_q --list-runs $workflow_q success)+change-prompt(run success> )" \
          --bind "ctrl-f:reload($script_path_q --list-runs $workflow_q failure)+change-prompt(run failure> )" \
          --bind "ctrl-l:reload($script_path_q --list-runs $workflow_q cancelled)+change-prompt(run cancelled> )" \
          --bind "ctrl-g:reload($script_path_q --list-runs $workflow_q in_progress)+change-prompt(run in_progress> )"
  ) || true

  [ -n "$selected" ] || return 0
  gh run view "${selected%%$'\t'*}" --web
}

if [ "${1:-}" = "--list-runs" ]; then
  [ -n "${2:-}" ] || { echo "gh-wf: workflow file が必要です" >&2; exit 1; }
  list_runs "$2" "${3:-}"
  exit 0
fi

if [ "${1:-}" = "--runs" ]; then
  [ -n "${2:-}" ] || { echo "gh-wf: workflow file が必要です" >&2; exit 1; }
  show_runs "$2"
  exit 0
fi

# Enter のデフォルトは run 選択。--web / -w でブラウザに切り替える。
enter_action="$script_path_q --runs {}"
enter_bind="enter:execute($enter_action)"
header='Enter runs / Ctrl-O web / Ctrl-E edit / Ctrl-Y copy'
if [ "${1:-}" = "--web" ] || [ "${1:-}" = "-w" ]; then
  enter_action='gh workflow view {} --web'
  enter_bind="enter:execute-silent($enter_action)+abort"
  header='Enter web / Ctrl-R runs / Ctrl-E edit / Ctrl-Y copy'
fi

# 現存する yaml だけを列挙（削除済みは物理的に存在しないので自然に除外される）。
shopt -s nullglob
files=("$dir"/*.yml "$dir"/*.yaml)
(( ${#files[@]} )) || { echo "gh-wf: ワークフローファイルがありません ($dir)" >&2; exit 0; }

# fzf の {} は shell 用に自動でクォートされる。
# "$dir/{}" のように追加で囲むと、クォート文字がファイル名に混ざる。
export GH_WF_WORKFLOW_DIR="$dir"
preview='file=$GH_WF_WORKFLOW_DIR/{}; bat --color=always --style=numbers,header "$file" 2>/dev/null || cat "$file"'

printf '%s\n' "${files[@]##*/}" \
  | fzf \
      --prompt 'workflow> ' \
      --preview "$preview" \
      --preview-window=right:65%:wrap \
      --header "$header" \
      --bind "$enter_bind" \
      --bind "ctrl-o:execute-silent(gh workflow view {} --web)+abort" \
      --bind "ctrl-r:execute($script_path_q --runs {})" \
      --bind "ctrl-e:execute(file=\$GH_WF_WORKFLOW_DIR/{}; \${EDITOR:-vi} \"\$file\")" \
      --bind "ctrl-y:execute-silent(printf %s {} | pbcopy)"
