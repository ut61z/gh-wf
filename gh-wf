#!/usr/bin/env bash
#
# gh-wf: カレントリポの .github/workflows/ を fzf で検索・プレビューする gh 拡張。
#
# Actions UI と違い、データソースをローカルの現存 yaml にしているので
# 「削除済みだが run 履歴が残っているワークフロー」は自動的に除外される。
#
# Usage:
#   gh wf            # Enter = そのワークフローの run 一覧
#   gh wf --web      # Enter = ブラウザでそのワークフローを開く
#
# Keybinds (fzf 内):
#   Enter   起動オプションに応じて run 一覧 or ブラウザ
#   Ctrl-O  ブラウザでワークフローを開く
#   Ctrl-R  run 一覧を表示
#   Ctrl-E  $EDITOR で yaml を開く
#   Ctrl-Y  ファイル名をクリップボードにコピー
#
set -euo pipefail

for c in fzf gh; do
  command -v "$c" >/dev/null || { echo "gh-wf: '$c' が必要です" >&2; exit 1; }
done

root=$(git rev-parse --show-toplevel 2>/dev/null) \
  || { echo "gh-wf: git リポジトリ内で実行してください" >&2; exit 1; }
dir="$root/.github/workflows"
[ -d "$dir" ] || { echo "gh-wf: $dir がありません" >&2; exit 1; }

# Enter のデフォルトは run 一覧。--web / -w でブラウザに切り替える。
enter_action='gh run list --workflow={} --limit 20 | less -R'
enter_bind="enter:execute($enter_action)"
header='Enter: run一覧 / Ctrl-O: ブラウザ / Ctrl-E: エディタ / Ctrl-Y: コピー'
if [ "${1:-}" = "--web" ] || [ "${1:-}" = "-w" ]; then
  enter_action='gh workflow view {} --web'
  enter_bind="enter:execute-silent($enter_action)+abort"
  header='Enter: ブラウザ / Ctrl-R: run一覧 / Ctrl-E: エディタ / Ctrl-Y: コピー'
fi

# 現存する yaml だけを列挙（削除済みは物理的に存在しないので自然に除外される）。
shopt -s nullglob
files=("$dir"/*.yml "$dir"/*.yaml)
(( ${#files[@]} )) || { echo "gh-wf: ワークフローファイルがありません ($dir)" >&2; exit 0; }

# fzf の {} は shell 用に自動でクォートされる。
# "$dir/{}" のように追加で囲むと、クォート文字がファイル名に混ざる。
export GH_WF_WORKFLOW_DIR="$dir"
preview='file=$GH_WF_WORKFLOW_DIR/{}; bat --color=always --style=numbers,header "$file" 2>/dev/null || cat "$file"'

printf '%s\n' "${files[@]##*/}" \
  | fzf \
      --prompt 'workflow> ' \
      --preview "$preview" \
      --preview-window=right:65%:wrap \
      --header "$header" \
      --bind "$enter_bind" \
      --bind "ctrl-o:execute-silent(gh workflow view {} --web)+abort" \
      --bind "ctrl-r:execute(gh run list --workflow={} --limit 20 | less -R)" \
      --bind "ctrl-e:execute(file=\$GH_WF_WORKFLOW_DIR/{}; \${EDITOR:-vi} \"\$file\")" \
      --bind "ctrl-y:execute-silent(printf %s {} | pbcopy)"
